# Neon PostgreSQL (required for admin tracking)
# Get from https://console.neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Local dev only: skip TLS certificate verification for Neon (Windows/corporate proxy SSL issues)
# Production on Cloudflare does not use this. Set to "false" to force strict TLS in dev.
NEON_TLS_SKIP_VERIFY=true

# Admin dashboard login (server-only, never prefix with VITE_)
ADMIN_PASSWORD=changeme
ADMIN_SECRET=changeme

# Supabase (legacy - optional if fully migrated to Neon)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
